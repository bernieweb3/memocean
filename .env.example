# REQUIRED: 32+ char random string for MCP API auth
# Generate: openssl rand -base64 32
API_SECRET_KEY=

# REQUIRED for client-side E2EE only
# Server should NOT have this in production zero-knowledge mode
# MEMOCEAN_MASTER_SECRET=

# REQUIRED per project: 32 random bytes hex
# Generate per project: openssl rand -hex 32
MEMOCEAN_PROJECT_SALT=

# Optional key rotation version
MEMOCEAN_KEY_VERSION=1

# LLM Providers (optional, for ocean_analyze)
GROQ_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_NIM_API_KEY=

# LLM Policy
MEMOCEAN_ALLOW_EXTERNAL_LLM=false
MEMOCEAN_PRIMARY_PROVIDER=groq
