# =============================================================================
# MemOcean SDK - Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in the values for your environment.
# Only the variables actually consumed by the SDK are listed here.
# =============================================================================

# -----------------------------------------------------------------------------
# Crypto (required)
# -----------------------------------------------------------------------------
# The high-entropy user-held secret used by HKDF to derive all keys.
# Accepts hex, base64, or a strong utf-8 passphrase. Recommended: 32 random
# bytes encoded as hex (64 chars).
# Example: openssl rand -hex 32
MEMOCEAN_MASTER_SECRET=

# Optional HKDF salt shared across a project. Default: empty string.
# Rotating this invalidates every previously-stored memory (keys change).
MEMOCEAN_HKDF_SALT=

# -----------------------------------------------------------------------------
# LLM providers (Learn engine)
# -----------------------------------------------------------------------------
# Which provider to try first. Must match a key below if you set one.
# Allowed values: groq | ollama-cloud | openrouter | nvidia-nim
# If unset, providers are tried in the order: groq -> ollama-cloud ->
# openrouter -> nvidia-nim.
# LLM_PRIMARY_PROVIDER=groq

# Groq (primary: ultra-fast inference)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama Cloud (fallback: high-context reasoning)
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_MODEL=llama3.1:70b

# OpenRouter (backup: 100+ models)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct

# NVIDIA NIM (enterprise: proprietary models)
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_MODEL=meta/llama-3.1-70b-instruct

# -----------------------------------------------------------------------------
# Cloudflare bindings
# -----------------------------------------------------------------------------
# In a Workers deployment these are injected by the runtime (wrangler.toml /
# `env` parameter) and do NOT need to be set here. They are listed for
# reference when running the SDK outside Workers (Node.js, Bun).
#
# DB   - Cloudflare D1 database binding
# R2   - Cloudflare R2 bucket binding
# KV   - Cloudflare KV namespace binding
#
# When running standalone, pass concrete instances to the SDK constructor
# instead of relying on environment variables:
#
#   new MemOceanSDK({
#     masterSecret: process.env.MEMOCEAN_MASTER_SECRET!,
#     bindings: {
#       DB: someD1Database,
#       R2: someR2Bucket,
#       KV: someKVNamespace,
#     },
#   });
